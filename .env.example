# CodeForge Configuration
# Copy this file to .env and adjust values for your environment

# ── LLM Configuration ─────────────────────────
# Ollama server address
OLLAMA_HOST=http://localhost:11434
# Model to use (llama3.2, codellama, mistral, etc.)
OLLAMA_MODEL=llama3.2
# Temperature for generation (0.0 = deterministic, 1.0 = creative)
OLLAMA_TEMPERATURE=0.2
# Maximum tokens per response
OLLAMA_MAX_TOKENS=4096
# Request timeout in seconds
OLLAMA_TIMEOUT=120

# ── Agent Configuration ──────────────────────
# Maximum time an agent can work on a single task (seconds)
AGENT_TIMEOUT_SECONDS=300
# Maximum retries for failed agent tasks
MAX_RETRY_ATTEMPTS=3
# Delay between retries (seconds)
RETRY_DELAY_SECONDS=5

# ── Storage Configuration ────────────────────
# Where project state is stored (relative to output project)
STATE_STORE_PATH=.codeforge/state
# Where checkpoints are stored
CHECKPOINT_PATH=.codeforge/checkpoints

# ── Git Configuration ────────────────────────
GIT_AUTHOR_NAME=CodeForge AI
GIT_AUTHOR_EMAIL=codeforge@ai.local

# ── Dashboard Configuration ──────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501

# ── Approval Configuration ───────────────────
# Auto-approve low-risk style fixes without human intervention
AUTO_APPROVE_STYLE_FIXES=true
# Minutes before an approval request times out (0 = never)
APPROVAL_TIMEOUT_MINUTES=30

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
